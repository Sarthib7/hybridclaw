{
  "name": "@hybridaione/hybridclaw",
  "version": "0.4.2",
  "type": "module",
  "description": "Personal AI assistant bot for Discord, powered by HybridAI",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "hybridclaw": "dist/cli.js"
  },
  "files": [
    "dist/",
    "container/dist/",
    "skills/",
    "templates/",
    "docs/",
    "container/Dockerfile",
    "container/.dockerignore",
    "container/package.json",
    "container/package-lock.json",
    "container/tsconfig.json",
    "container/src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "AGENTS.md",
    "SECURITY.md",
    "TRUST_MODEL.md",
    "config.example.json"
  ],
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('container/dist',{recursive:true,force:true});\"",
    "build": "npm --prefix container run build && tsc && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit --noUnusedLocals --noUnusedParameters",
    "check": "biome check src",
    "format": "biome check --write src",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts --passWithNoTests",
    "test:e2e": "vitest run --config vitest.e2e.config.ts --passWithNoTests",
    "test:live": "vitest run --config vitest.live.config.ts --passWithNoTests",
    "setup": "npm --prefix container install",
    "dev": "tsx src/cli.ts gateway",
    "gateway": "tsx src/cli.ts gateway",
    "tui": "tsx src/cli.ts tui",
    "start": "node dist/cli.js gateway",
    "build:container": "node -e \"const cp=require('node:child_process');const image=process.env.HYBRIDCLAW_CONTAINER_IMAGE||'hybridclaw-agent';const r=cp.spawnSync('docker',['build','-t',image,'./container'],{stdio:'inherit'});if(r.error) throw r.error;process.exit(r.status ?? 1);\"",
    "prepack": "npm run clean && npm run build && npm run release:check",
    "release:check": "node ./scripts/release-check.mjs",
    "publish:dry": "npm publish --access public --dry-run",
    "prepare": "command -v git >/dev/null 2>&1 && test -w .git/config && husky || true"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cron-parser": "^5.5.0",
    "discord.js": "^14.25.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.394",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3"
  },
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.82"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.13",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
